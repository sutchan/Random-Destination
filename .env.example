# Random Destination Wheel - Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# REQUIRED - API Keys
# =============================================================================

# Gemini API Key for AI-powered destination descriptions
# Get your API key from: https://aistudio.google.com/apikey
# IMPORTANT: This is a server-side only variable (no NEXT_PUBLIC_ prefix)
# The frontend calls /api/destination which uses this server-side key
GEMINI_API_KEY="your_gemini_api_key_here"

# =============================================================================
# OPTIONAL - Application Settings
# =============================================================================

# Application URL (used for self-referential links and OAuth callbacks)
# Automatically injected by Google AI Studio in production
APP_URL="http://localhost:3000"

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Set to 'development' for verbose logging
NODE_ENV="development"

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# For Google AI Studio deployment:
# 1. Add GEMINI_API_KEY to the Secrets panel
# 2. APP_URL is automatically injected by the platform
#
# For local development:
# 1. Copy this file to .env.local
# 2. Fill in your GEMINI_API_KEY from Google AI Studio
# 3. Restart the dev server
